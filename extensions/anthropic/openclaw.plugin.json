  "providerAuthChoices": [
    {
      "provider": "anthropic",
      "method": "cli",
      "choiceId": "anthropic-cli",
      "deprecatedChoiceIds": ["claude-cli"],
      "choiceLabel": "Anthropic Claude CLI",
