  "contracts": {
    "mediaUnderstandingProviders": ["anthropic"]
  },
  "mediaUnderstandingProviderMetadata": {
    "anthropic": {
      "capabilities": ["image"],
      "defaultModels": {
        "image": "claude-opus-4-7"
