        "envVars": ["XIAOMI_API_KEY"]
      },
      {
        "id": "xiaomi-token-plan",
        "envVars": ["XIAOMI_TOKEN_PLAN_API_KEY"]
      }
    ]
  },
  "modelCatalog": {
